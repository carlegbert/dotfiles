if [ -x /usr/bin/dircolors ]; then
  # Linux with GNU coreutils
  test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
  alias ls='ls --color=auto'
  #alias dir='dir --color=auto'
  #alias vdir='vdir --color=auto'

  alias grep='grep --color=auto'
  alias fgrep='fgrep --color=auto'
  alias egrep='egrep --color=auto'

  alias setclip='xclip -selection c'
  alias getclip='xclip -selection clipboard -o'
  alias clearclip='xclip -selection c < /dev/null'
elif [[ "$OSTYPE" == "darwin"* ]]; then
  # macOS — BSD ls uses -G for color
  alias ls='ls -G'

  alias grep='grep --color=auto'
  alias fgrep='fgrep --color=auto'
  alias egrep='egrep --color=auto'

  alias setclip='pbcopy'
  alias getclip='pbpaste'
  alias clearclip='pbcopy < /dev/null'
fi

# laziness aliases
alias ..='_..' # see ~/.shell/scripts
alias ...='_.. 2'
alias ....='_.. 3'
alias die='shutdown now'
alias ll='ls -ahlF'
alias la='ls -A'
alias l='ls -CF'
alias mkdir='mkdir -pv'
alias ports='netstat -tuvanp'
alias cp='cp -iv'
alias e='"$EDITOR"'
alias esudo='sudo -E "$EDITOR"'
alias tempdir='cd $(mktemp -d)'
alias doco="docker compose"
alias ku="kubectl"

# random throwaway password
alias randpass='openssl rand -base64 32 | setclip'

# hack for virtualenv pip freeze bug
alias pipfreeze='pip freeze | grep -v "pkg-resources"'

# racket repl for SICP exercises
alias sicp='racket -i -p neil/sicp -l xrepl'

# open vim-magit buffer
alias magit='"$EDITOR" -c MagitOnly'

alias racket-langserver='racket -l racket-langserver'

alias gkb='ghostty +list-keybinds | fzf'

alias dots='git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
